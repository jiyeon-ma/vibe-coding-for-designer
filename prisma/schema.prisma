// Vibe Archive — Prisma schema
// 인증 없음. 1인 사용 가정.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ===== Category: 기본 4개 + 사용자 추가 =====

model Category {
  id         String      @id @default(uuid())
  slug       String      @unique             // visual / dev / reference / unclassified / kebab-case 사용자 정의
  label      String                          // 표시명
  isSystem   Boolean     @default(false)     // 기본 4개는 true (삭제·slug 변경 불가)
  order      Int         @default(0)         // Vibe Archived 컬럼 순서
  createdAt  DateTime    @default(now())
  references Reference[]
}

// ===== Reference: 수집된 링크 =====

model Reference {
  id            String    @id @default(uuid())
  url           String    @unique
  title         String?
  ogImage       String?
  ogDescription String?
  aiSummary     String?
  categoryId    String?
  category      Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  aiSlug        String?                       // AI가 처음 분류한 slug 기록 (디버그용)
  aiConfidence  Float?
  status        Status    @default(UNREAD)
  source        Source    @default(MANUAL)
  rawAiResponse Json?
  createdAt     DateTime  @default(now())
  archivedAt    DateTime?
  tags          ReferenceTag[]

  @@index([status, categoryId, createdAt])
}

enum Status {
  UNREAD
  ARCHIVED
}

enum Source {
  MANUAL
  TELEGRAM
}

// ===== Tags =====

model Tag {
  id   String         @id @default(uuid())
  name String         @unique
  refs ReferenceTag[]
}

model ReferenceTag {
  referenceId String
  tagId       String
  reference   Reference @relation(fields: [referenceId], references: [id], onDelete: Cascade)
  tag         Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([referenceId, tagId])
}

// ===== Visual Dictionary: 감성 키워드 ↔ AI 프롬프트 =====

model VisualDictionary {
  id              String   @id @default(uuid())
  keyword         String
  vibeDescription String?
  prompts         Prompt[]
  createdAt       DateTime @default(now())
}

model Prompt {
  id              String           @id @default(uuid())
  dictionaryId    String
  tool            Tool
  body            String
  exampleImageUrl String?
  dictionary      VisualDictionary @relation(fields: [dictionaryId], references: [id], onDelete: Cascade)
}

enum Tool {
  MIDJOURNEY
  THREEJS
  DALLE
  STABLE_DIFFUSION
  OTHER
}

// ===== Dev Dictionary: 용어 · 개념 사전 =====

model DevDictionary {
  id          String   @id @default(uuid())
  keyword     String                          // "rebase", "tool use", "API"
  description String                          // 한 줄 설명
  example     String?                         // 예시 코드/명령어 (mono code block)
  createdAt   DateTime @default(now())
}
